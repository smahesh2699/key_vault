# Database configuration
# Local default is sqlite. For PostgreSQL use: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./keyvault.db

# JWT Security
# Generate random keys with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=supersecretjwtkeychangeinproduction123456
JWT_REFRESH_SECRET=supersecretjwtrefreshkeychangeinproduction123456
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Fernet Key for API Key Encryption at Rest
# Generate a Fernet key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=YOUR_FERNET_KEY_HERE

# GitHub Token for public code scanning
GITHUB_TOKEN=YOUR_GITHUB_PERSONAL_ACCESS_TOKEN

# Rate Limiting
RATE_LIMIT_LOGIN_PER_MIN=5

# Optional SMTP Settings (uncomment if using email alerts)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@keyvault.com
